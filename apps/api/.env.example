# ── LLM Provider ─────────────────────────────────────────────────────────────
# Which provider to use: "groq" (default, cloud) or "ollama" (local/offline)
LLM_PROVIDER=groq

# ── Groq (cloud) ─────────────────────────────────────────────────────────────
# Get your key at https://console.groq.com
GROQ_API_KEY=gsk_...
# Optional: override the default model
# GROQ_MODEL=llama-3.3-70b-versatile

# ── Ollama (offline) ─────────────────────────────────────────────────────────
# Run Ollama locally: https://ollama.com — then: ollama pull llama3.2
# The API is OpenAI-compatible; only models with reliable tool-calling work well.
# Recommended: llama3.2, qwen2.5, mistral-nemo
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3.2

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000
